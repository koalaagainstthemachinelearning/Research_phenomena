<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Abrar Islam  | AI/ML Research</title>
    <meta name="description" content="AI/ML researcher building models, writing papers, and documenting experiments." />
  </head>

  <body style="
    margin: 0;
    font-family: system-ui, -apple-system, sans-serif;
    background: radial-gradient(circle at top, #111827, #0b0b0b);
    color: white;
  ">

    <!-- Container -->
    <div style="max-width: 1000px; margin: auto; padding: 80px 20px;">

      <!-- Hero -->
      <div style="text-align: center;">
        
        <h1 style="
          font-size: 52px;
          margin-bottom: 10px;
          letter-spacing: -1px;
        ">
          Abrar Islam ~ koala
        </h1>

        <p style="
          font-size: 18px;
          opacity: 0.75;
          max-width: 600px;
          margin: auto;
        ">
          AI/ML researcher building models, analyzing papers, and documenting experiments in machine learning and data-driven systems.
        </p>

        <!-- Buttons -->
        <div style="margin-top: 30px; display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">

          <a href="/blog" style="
            padding: 10px 18px;
            border-radius: 10px;
            background: white;
            color: black;
            text-decoration: none;
            font-weight: 500;
          ">
            Read Blog
          </a>

          <a href="/projects" style="
            padding: 10px 18px;
            border-radius: 10px;
            border: 1px solid rgba(255,255,255,0.2);
            color: white;
            text-decoration: none;
          ">
            View Projects
          </a>

          <a href="https://github.com/" target="_blank" style="
            padding: 10px 18px;
            border-radius: 10px;
            border: 1px solid rgba(255,255,255,0.2);
            color: white;
            text-decoration: none;
          ">
            GitHub
          </a>

        </div>
      </div>

      <!-- Sections -->
      <div style="margin-top: 80px; display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px;">

        <div style="padding: 20px; border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; background: rgba(255,255,255,0.03);">
          <h3>Research Focus</h3>
          <p style="opacity: 0.7;">Machine learning, deep learning, and applied AI systems.</p>
        </div>

        <div style="padding: 20px; border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; background: rgba(255,255,255,0.03);">
          <h3>What I Do</h3>
          <p style="opacity: 0.7;">Experiments, model building, paper analysis, and implementation.</p>
        </div>

        <div style="padding: 20px; border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; background: rgba(255,255,255,0.03);">
          <h3>Writing</h3>
          <p style="opacity: 0.7;">Technical blogs, research notes, and experiment logs.</p>
        </div>

      </div>

      <!-- Footer -->
      <div style="margin-top: 80px; text-align: center; opacity: 0.5; font-size: 14px;">
        © 2026 Abrar Islam — AI/ML Research Portfolio
      </div>

    </div>

  </body>
</html>